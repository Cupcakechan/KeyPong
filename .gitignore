# ==============================================================
#  Unity 6 .gitignore  —  place at the ROOT of the Unity project
#  (sibling to Assets/, Packages/, ProjectSettings/)
#  Source: github/gitignore Unity.gitignore + WebGL/Rider extras
# ==============================================================

# Unity-generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size and may hold sensitive data
/[Mm]emoryCaptures/

# Recordings can get large
/[Rr]ecordings/

# Asset meta data should only be ignored when the asset itself is ignored
!/[Aa]ssets/**/*.meta

# Autogenerated JetBrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio / Rider caches
.vs/
.idea/
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity generated meta files (for files that are ignored)
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# OS files
.DS_Store
Thumbs.db
*.slnx
.vscode/
/Builds/